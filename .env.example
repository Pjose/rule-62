# Postgres connection string (Neon, Supabase, Railway, or any Postgres provider)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Random long secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Optional: shared secret to protect the cron endpoint that rolls schedules forward.
# If set, Vercel Cron must send it as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace-with-a-long-random-string

# Base URL of the deployed app (used in a couple of links). Example: https://yourapp.vercel.app
APP_URL=http://localhost:3000
